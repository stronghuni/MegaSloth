{
  "name": "megasloth",
  "version": "1.0.0",
  "description": "MegaSloth - AI-Powered Repository Operations Agent that automates GitHub, GitLab, and Bitbucket workflows",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "megasloth": "dist/cli/index.js"
  },
  "keywords": [
    "ai-agent",
    "github-automation",
    "devops",
    "ci-cd",
    "code-review",
    "gitlab",
    "bitbucket",
    "automation",
    "llm",
    "claude",
    "openai",
    "gemini",
    "repository-automation",
    "pr-review",
    "issue-triage"
  ],
  "author": "stronghuni",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stronghuni/MegaSloth.git"
  },
  "bugs": {
    "url": "https://github.com/stronghuni/MegaSloth/issues"
  },
  "homepage": "https://github.com/stronghuni/MegaSloth#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node --input-type=commonjs -e \"require('fs').cpSync('src/skills/builtin','dist/skills/builtin',{recursive:true})\"",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "tsx src/__tests__/e2e-live.test.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.2",
    "@gitbeaker/rest": "^40.5.0",
    "@google/genai": "^1.42.0",
    "@mozilla/readability": "^0.6.0",
    "@slack/web-api": "^7.8.0",
    "better-sqlite3": "^11.6.0",
    "bitbucket": "^2.12.0",
    "bullmq": "^5.30.1",
    "commander": "^14.0.3",
    "croner": "^9.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "jsdom": "^28.1.0",
    "octokit": "^4.1.0",
    "openai": "^6.22.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "turndown": "^7.2.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.19.7",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}

# MegaSloth Configuration

# Server Ports
HTTP_PORT=13000
WEBHOOK_PORT=3001
WEBSOCKET_PORT=18789

# Database
DATABASE_URL=.megasloth/data/megasloth.db

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# GitHub
GITHUB_TOKEN=your_github_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# GitLab
GITLAB_TOKEN=your_gitlab_token
GITLAB_URL=https://gitlab.com
GITLAB_WEBHOOK_SECRET=your_gitlab_webhook_secret

# Bitbucket
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password
BITBUCKET_WEBHOOK_SECRET=your_bitbucket_webhook_secret

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_DEFAULT_CHANNEL=general

# Jenkins
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=your_jenkins_api_token

# Kubernetes (uses kubectl from PATH; configure via kubeconfig)
# KUBECONFIG=~/.kube/config

# Logging
LOG_LEVEL=info
